NODE_ENV=development
PORT=4100
# Allowed CORS origin(s) for the frontend: one URL, a comma-separated list, or "*" for any origin.
FRONTEND_URL=https://www.pay-panda.app,https://pay-panda.app,http://localhost:5174
PUBLIC_APP_URL=https://www.pay-panda.app
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/pay_panda?schema=public
JWT_SECRET=replace-with-at-least-32-random-characters
TOKEN_ENCRYPTION_KEY=replace-with-64-hex-characters
ACCESS_TOKEN_TTL=15m
USER_ACCESS_TOKEN_TTL=30m
ADMIN_ACCESS_TOKEN_TTL=4h
PAYMENT_EXPIRY_MINUTES=10
LIVE_VERIFY_THROTTLE_MS=5000
RECONCILIATION_INTERVAL_MS=1800000
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_PASS=
SMTP_FROM=Pay-Panda <no-reply@example.com>
EMAIL_FROM=Pay-Panda <no-reply@example.com>
EMAIL_VERIFICATION_HOURS=24
PASSWORD_RESET_MINUTES=30
LOGIN_OTP_MINUTES=10
# First super-admin bootstrap (used once by `npm run seed`; leave unset to skip seeding).
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=
SUPER_ADMIN_NAME=Super Admin
